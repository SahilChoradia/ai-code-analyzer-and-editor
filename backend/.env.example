# Server
NODE_ENV=development
PORT=4000

# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017/ai_code_engine

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Ingestion (ZIP max size in MB, Git clone timeout, optional temp root)
MAX_UPLOAD_MB=20
GITHUB_CLONE_TIMEOUT_MS=120000
# INGEST_TEMP_ROOT=C:\\Temp\\ace-ingest
# Optional: persistent clones for Fix & Edit (GitHub OAuth projects). Default: <OS tmp>/ace-edit-workspaces
# PROJECT_EDIT_WORKSPACE_ROOT=C:\\Temp\\ace-edit-workspaces

# AST parsing (Tree-sitter WASM)
AST_MAX_FILE_BYTES=2097152
AST_MAX_DEPTH=64
AST_MAX_NODES_PER_FILE=25000
AST_MAX_TEXT_LEN=256

# Static analysis thresholds (STEP 4)
ANALYSIS_COMPLEXITY_WARN_THRESHOLD=10
ANALYSIS_COMPLEXITY_ERROR_THRESHOLD=15
ANALYSIS_MAX_NESTING_DEPTH=5
ANALYSIS_LARGE_FUNCTION_NODES=400

# API rate limit (per IP, applies to all routes except /health and /ready)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
# Optional: absolute path to folder containing tree-sitter *.wasm files (default: <cwd>/wasm)
# AST_WASM_ROOT=

# STEP 7 — Google Gemini (optional; analysis still works without a key)
# Create a key in Google AI Studio: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_API_BASE=https://generativelanguage.googleapis.com
# GEMINI_MODEL=gemini-2.0-flash
# AI_REQUEST_TIMEOUT_MS=90000
# AI_MAX_RETRIES=2
# AI_MAX_FILES=8
# AI_MAX_OUTLINE_NODES=450
# AI_MAX_OUTLINE_CHARS=3200
# AI_BATCH_SIZE=2
# AI_MAX_CONCURRENT_BATCHES=2
# AI_BATCH_CHAR_BUDGET=12000
# AI_OUTLINE_CHUNK_CHARS=4000

# STEP 9 — Redis + BullMQ (optional). Without REDIS_URL, POST /analyze runs synchronously.
# REDIS_URL=redis://127.0.0.1:6379
# QUEUE_AFTER_INGEST=false
# GEMINI_CACHE_TTL_SEC=604800
# WORKER_CONCURRENCY=2
# WORKER_EMBEDDED=true
# Set WORKER_EMBEDDED=false and run: npm run worker (separate process)

# GitHub OAuth (required for sign-in + repo list + /ingest/github)
# Create an OAuth App: https://github.com/settings/developers
# Authorization callback URL must match CALLBACK_URL exactly (e.g. http://localhost:4000/auth/github/callback)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# CALLBACK_URL=http://localhost:4000/auth/github/callback
# SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# FRONTEND_URL=http://localhost:3000
