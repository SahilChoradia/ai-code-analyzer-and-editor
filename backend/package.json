{
  "name": "ai-code-engine-backend",
  "version": "0.1.0",
  "private": true,
  "description": "AI Code Understanding & Refactoring Engine — API server",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'); if(fs.existsSync('dist')){fs.rmSync('dist',{recursive:true})}\"",
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "worker": "node dist/worker.main.js",
    "dev:worker": "tsx watch src/worker.main.ts",
    "postinstall": "node scripts/download-wasm.mjs",
    "setup:wasm": "node scripts/download-wasm.mjs",
    "test": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bullmq": "^5.73.0",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "mongoose": "^8.9.5",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "simple-git": "^3.27.0",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.24.1",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "@types/adm-zip": "^0.5.7",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/express-session": "^1.18.2"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2"
  }
}
