# Used by docker compose for the backend service (copy to .env.docker — do not commit secrets)

MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/ai_code_engine
GEMINI_API_KEY=

# GitHub OAuth (required for UI sign-in when using the new flow)
# CALLBACK_URL must be reachable from the browser (e.g. http://localhost:4000/auth/github/callback)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# CALLBACK_URL=http://localhost:4000/auth/github/callback
# SESSION_SECRET=replace-with-32-plus-random-chars-minimum
# FRONTEND_URL=http://localhost:3000

# Optional tuning (defaults are fine for most demos)
# GEMINI_MODEL=gemini-2.0-flash
# QUEUE_AFTER_INGEST=false
# WORKER_CONCURRENCY=2
